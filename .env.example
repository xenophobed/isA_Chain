# Network Configuration
NETWORK_ID=isa-chain-testnet
CHAIN_ID=15489
NODE_ENV=development

# Blockchain Core
BLOCKCHAIN_DATA_DIR=./data
BLOCKCHAIN_PORT=8080
BLOCKCHAIN_RPC_PORT=8545
BLOCKCHAIN_WS_PORT=8546

# P2P Network
P2P_PORT=30303
BOOTSTRAP_NODES="enode://..."
DISCOVERY_PORT=30301

# Database
DATABASE_URL=postgresql://localhost:5432/isachain
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://localhost:27017/isachain

# MCP Integration
MCP_SERVER_URL=http://localhost:8081
MCP_API_KEY=your-mcp-api-key
AGENT_FRAMEWORK_URL=http://localhost:8082

# External Services
INFURA_PROJECT_ID=your-infura-project-id
ALCHEMY_API_KEY=your-alchemy-api-key
MORALIS_API_KEY=your-moralis-api-key

# Oracle Configuration
CHAINLINK_NODE_URL=http://localhost:6688
ORACLE_PRIVATE_KEY=your-oracle-private-key
PRICE_FEED_UPDATE_INTERVAL=60

# Exchange Configuration
EXCHANGE_API_PORT=8090
TRADING_ENGINE_PORT=8091
MARKET_DATA_PORT=8092
CUSTODY_SERVICE_URL=http://localhost:8093

# Security
JWT_SECRET=your-jwt-secret
ENCRYPTION_KEY=your-encryption-key
ADMIN_PRIVATE_KEY=your-admin-private-key

# External APIs
COINGECKO_API_KEY=your-coingecko-api-key
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET_KEY=your-binance-secret

# Development
DEBUG=true
LOG_LEVEL=debug
ENABLE_TELEMETRY=false

# Testing
TEST_PRIVATE_KEY=your-test-private-key
TESTNET_RPC_URL=http://localhost:8545
FAUCET_URL=http://localhost:8080/faucet

# Frontend
NEXT_PUBLIC_CHAIN_ID=15489
NEXT_PUBLIC_RPC_URL=http://localhost:8545
NEXT_PUBLIC_WS_URL=ws://localhost:8546
NEXT_PUBLIC_EXPLORER_URL=http://localhost:3001

# Analytics
ANALYTICS_API_URL=http://localhost:8095
METRICS_PORT=9090
GRAFANA_URL=http://localhost:3000