{
  "name": "@isa-chain/mcp-bridge",
  "version": "1.0.0",
  "description": "MCP Bridge for isA_Chain - Agent/Model/MCP Integration Layer",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
